rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user has an admin grant
    function hasAdminGrant(pollId) {
      return exists(/databases/$(database)/documents/polls/$(pollId)/adminGrants/$(request.auth.uid));
    }

    // Helper to verify admin token
    function isValidAdminToken(pollId, token) {
      return exists(/databases/$(database)/documents/polls/$(pollId)/adminTokens/$(token));
    }

    match /polls/{pollId} {
      // Anyone can read (adminToken is NOT in this document)
      allow read: if true;
      
      // Authenticated users can create a poll (no adminToken allowed in doc)
      allow create: if request.auth != null
                    && request.resource.data.status == "OPEN"
                    && request.resource.data.title.size() > 0
                    && !("adminToken" in request.resource.data)
                    && request.resource.data.organizerUid == request.auth.uid;
      
      allow update: if request.auth != null 
                    && (
                      request.auth.uid == resource.data.organizerUid
                      || hasAdminGrant(pollId)
                    )
                    && request.resource.data.createdAt == resource.data.createdAt
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['adminToken', 'organizerUid']);
      
      allow delete: if false;

      // Token storage — used for verification via exists()
      match /adminTokens/{token} {
        allow create: if request.auth != null 
                      && get(/databases/$(database)/documents/polls/$(pollId)).data.organizerUid == request.auth.uid;
        allow read, update, delete: if false;
      }

      // Admin grants — proof of token ownership
      match /adminGrants/{grantUid} {
        allow read: if request.auth != null && request.auth.uid == grantUid;
        
        // Create/update: must provide correct adminToken
        allow create, update: if request.auth != null
          && request.auth.uid == grantUid
          && isValidAdminToken(pollId, request.resource.data.adminToken);
        
        allow delete: if false;
      }

      match /votes/{voteId} {
        // Votes are public to read (excluding private data)
        allow read: if true;
        
        // Anyone can create their own vote if the poll is open
        allow create: if request.auth != null
          && request.resource.data.participantUid == request.auth.uid
          && get(/databases/$(database)/documents/polls/$(pollId)).data.status == "OPEN";

        // Only the original voter can update their own vote
        allow update: if request.auth != null
          && resource.data.participantUid == request.auth.uid
          && request.resource.data.participantUid == request.auth.uid
          && get(/databases/$(database)/documents/polls/$(pollId)).data.status == "OPEN";
          
        allow delete: if request.auth != null && resource.data.participantUid == request.auth.uid;

        // Private data subcollection (e.g. emails)
        match /private/data {
          // Only the poll organizer, managers, or the voter themselves can read the private data
          allow read: if request.auth != null 
                      && (request.auth.uid == get(/databases/$(database)/documents/polls/$(pollId)).data.organizerUid
                          || request.auth.uid == resource.data.participantUid
                          || hasAdminGrant(pollId));
          
          allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.participantUid
                      && get(/databases/$(database)/documents/polls/$(pollId)).data.status == "OPEN";

          allow update: if request.auth != null
                      && resource.data.participantUid == request.auth.uid
                      && request.auth.uid == request.resource.data.participantUid
                      && get(/databases/$(database)/documents/polls/$(pollId)).data.status == "OPEN";
        }
      }
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
