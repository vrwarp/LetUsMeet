rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. KEYSTORE — only collection using Firebase Auth for security
    match /users/{userId}/keystore/{entryId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId
        && (
          // Standard poll keystore entry
          request.resource.data.keys().hasAll(['pollId', 'wrappedPayload', 'iv', 'updatedAt']) ||
          // Identity verification entry
          (entryId == 'identity_verification' && request.resource.data.keys().hasAll(['ciphertext', 'iv', 'nonce', 'version']))
        );
    }

    // 2. BLIND LEDGER
    match /polls/{pollId} {
      // Anyone can read the metadata shell and the event stream.
      // Privacy is enforced via client-side cryptography.
      allow read: if true;
      
      // Creating the namespace shell
      allow create: if true;
      allow update, delete: if false;

      match /events/{eventId} {
        allow read: if true;
        
        // Append-only invariant
        allow create: if request.resource.data.keys().hasAll(['eventId', 'createdAt', 'encryptedData', 'iv'])
          && request.resource.data.createdAt == request.time;
        
        allow update, delete: if false;
      }
    }

    // 3. USER PROFILES
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
