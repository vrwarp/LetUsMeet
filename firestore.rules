rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is the organizer or has the admin token
    function isOrganizer(pollData) {
      return (request.auth != null && request.auth.uid == pollData.organizerUid) 
             || (request.resource.data.adminToken == pollData.adminToken);
    }

    match /polls/{pollId} {
      // Anyone can read a poll
      allow read: if true;
      
      // Anyone can create a poll
      allow create: if request.auth != null
                    && request.resource.data.status == "OPEN"
                    && request.resource.data.title.size() > 0;
      
      // Only the organizer (by UID or adminToken) can update
      allow update: if isOrganizer(resource.data)
                    && request.resource.data.createdAt == resource.data.createdAt; // Prevent changing creation date
      
      allow delete: if false; // Better to set status to DELETED if needed

      match /votes/{voteId} {
        // Votes are public to read
        allow read: if true;
        
        // Anyone can create/update their own vote if the poll is open
        allow create, update: if request.auth != null
          && request.resource.data.participantUid == request.auth.uid
          && get(/databases/$(database)/documents/polls/$(pollId)).data.status == "OPEN";
          
        allow delete: if request.auth != null && resource.data.participantUid == request.auth.uid;
      }
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
